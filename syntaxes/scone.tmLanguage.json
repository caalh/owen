{
  "scopeName": "source.scone",
  "name": "SCONE",
  "patterns": [
    { "include": "#comment" },
    { "include": "#block" },
    { "include": "#keyword" },
    { "include": "#string" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "match": "//.*$|!.*$",
      "name": "comment.line.scone"
    },
    "keyword": {
      "match": "\\b(type|id|origin|halfwidth|boundary|radii|fills|filltype|surfaces|cells|universes|geometry|nuclearData|materials|composition|temp|pop|active|inactive|XSdata|dataType|aceNeutronDatabase|collisionOperator|transportOperator|source|tally|map|response|handles|graph)\\b",
      "name": "keyword.control.scone"
    },
    "block": {
      "match": "\\b(\\w+)\\s*(?=\\{)",
      "name": "entity.name.section.scone"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.scone"
    },
    "number": {
      "match": "(?<![\\w.])-?\\d+\\.?\\d*([eE][+-]?\\d+)?\\b",
      "name": "constant.numeric.scone"
    }
  }
}

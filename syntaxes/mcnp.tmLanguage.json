{
  "scopeName": "source.mcnp",
  "name": "MCNP",
  "patterns": [
    { "include": "#comment" },
    { "include": "#material" },
    { "include": "#tally" },
    { "include": "#keyword" },
    { "include": "#surface" },
    { "include": "#zaid" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "match": "^[cC]\\s.*$|\\$.*$",
      "name": "comment.line.mcnp"
    },
    "keyword": {
      "match": "\\b(mode|kcode|ksrc|sdef|nps|prdmp|print|phys|imp|fill|lat|u|trcl|like|but|vol|area|tr|ctme|rand|cut|tmp|wwn|wwp|dxt|fmesh)\\b",
      "name": "keyword.control.mcnp"
    },
    "material": {
      "match": "^(m[t]?\\d+)\\b",
      "name": "entity.name.material.mcnp"
    },
    "tally": {
      "match": "^(f[mcst]?\\d+|e\\d+|de\\d+|df\\d+|sd\\d+|tf\\d+)\\b",
      "name": "support.function.tally.mcnp"
    },
    "surface": {
      "match": "\\b(cz|cx|cy|pz|px|py|sz|so|sx|sy|rpp|rcc|rhp|hex|box|sph|sq|gq|tz|tx|ty|kz|kx|ky|p|c\\/x|c\\/y|c\\/z)\\b",
      "name": "storage.type.surface.mcnp"
    },
    "zaid": {
      "match": "\\b\\d{4,6}\\.\\d{2,3}[cCpPdDyYtThH]\\b",
      "name": "constant.other.zaid.mcnp"
    },
    "number": {
      "match": "(?<![\\w.])-?\\d+\\.?\\d*([eE][+-]?\\d+)?\\b",
      "name": "constant.numeric.mcnp"
    }
  }
}

{
  "scopeName": "source.serpent",
  "name": "Serpent",
  "patterns": [
    { "include": "#comment" },
    { "include": "#material" },
    { "include": "#pin" },
    { "include": "#keyword" },
    { "include": "#string" },
    { "include": "#zaid" },
    { "include": "#number" }
  ],
  "repository": {
    "comment": {
      "match": "%.*$|/\\*[\\s\\S]*?\\*/",
      "name": "comment.line.serpent"
    },
    "keyword": {
      "match": "\\b(set|surf|cell|lat|pin|dep|det|ene|mesh|plot|include|therm|mat|trans|src|branch|coef|fum|dtrans|umsh|solid)\\b",
      "name": "keyword.control.serpent"
    },
    "material": {
      "match": "(?<=^mat\\s)\\s*\\w+|(?<=^therm\\s)\\s*\\w+",
      "name": "entity.name.material.serpent"
    },
    "pin": {
      "match": "(?<=^pin\\s)\\s*\\w+|(?<=^surf\\s)\\s*\\w+|(?<=^cell\\s)\\s*\\w+",
      "name": "entity.name.type.serpent"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.serpent"
    },
    "zaid": {
      "match": "\\b\\d{4,6}\\.\\d{2,3}[cC]\\b",
      "name": "constant.other.zaid.serpent"
    },
    "number": {
      "match": "(?<![\\w.])-?\\d+\\.?\\d*([eE][+-]?\\d+)?\\b",
      "name": "constant.numeric.serpent"
    }
  }
}

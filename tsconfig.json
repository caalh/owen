{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "out",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    // The LSP packages only expose their entry points through package
    // "exports" maps, which classic node10 module resolution cannot see.
    // These paths give tsc the right .d.ts files; esbuild and Node itself
    // resolve the exports maps natively, so emit is unaffected.
    "paths": {
      "@belvoirdynamics/mcnp-workspace": ["./packages/mcnp-workspace/src/index"],
      "@belvoirdynamics/mcnp-workspace/*": ["./packages/mcnp-workspace/src/*"],
      "vscode-languageserver": ["node_modules/vscode-languageserver/lib/common/api"],
      "vscode-languageserver/node": ["node_modules/vscode-languageserver/lib/node/main"],
      "vscode-languageclient/node": ["node_modules/vscode-languageclient/lib/node/main"],
      "vscode-languageserver-textdocument": ["node_modules/vscode-languageserver-textdocument/lib/umd/main"],
      "vscode-jsonrpc": ["node_modules/vscode-jsonrpc/lib/common/api"],
      "vscode-jsonrpc/node": ["node_modules/vscode-jsonrpc/lib/node/main"],
      "vscode-languageserver-protocol": ["node_modules/vscode-languageserver-protocol/lib/common/api"],
      "vscode-languageserver-protocol/node": ["node_modules/vscode-languageserver-protocol/lib/node/main"],
      "vscode-languageserver-types": ["node_modules/vscode-languageserver-types/lib/umd/main"]
    }
  },
  "exclude": ["node_modules", ".vscode-test", "out"]
}

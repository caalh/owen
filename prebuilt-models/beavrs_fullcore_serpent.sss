% ===================== GEOMETRY CELLS =====================
surf sCB1  cyl 0.0 0.0 187.96     % core barrel inner
surf sCB2  cyl 0.0 0.0 193.675    % core barrel outer
surf sLin  cyl 0.0 0.0 219.150    % RPV liner inner
surf sRPVi cyl 0.0 0.0 219.710    % RPV inner
surf sRPVo cyl 0.0 0.0 241.3      % RPV outer

surf sNSi  cyl 0.0 0.0 194.84     % neutron-shield inner
surf sNSo  cyl 0.0 0.0 201.630    % neutron-shield outer
surf nsp1  plane -0.48480962025  0.87461970714 0.0 0.0
surf nsp2  plane -0.87461970714  0.48480962025 0.0 0.0
surf nsp3  plane -0.87461970714 -0.48480962025 0.0 0.0
surf nsp4  plane -0.48480962025 -0.87461970714 0.0 0.0
cell cCore   0 fill core    -sCB1 z0 -z460
cell cBarrel 0 ss304         sCB1 -sCB2 z0 -z460
cell cWtNS   0 water         sCB2 -sNSi z0 -z460
% neutron-shield panels: 4 SS304 pads at the octant positions
cell cNS1    0 ss304  sNSi -sNSo -nsp1  nsp2 z0 -z460
cell cNS2    0 ss304  sNSi -sNSo  nsp1 -nsp2 z0 -z460
cell cNS3    0 ss304  sNSi -sNSo -nsp3  nsp4 z0 -z460
cell cNS4    0 ss304  sNSi -sNSo  nsp3 -nsp4 z0 -z460
cell cNSw    0 water  sNSi -sNSo z0 -z460 (nsp1:-nsp2) (-nsp1:nsp2) (nsp3:-nsp4) (-nsp3:nsp4)
cell cDown   0 water         sNSo -sLin z0 -z460
cell cLiner  0 ss304         sLin -sRPVi z0 -z460
cell cRPV    0 carbonsteel   sRPVi -sRPVo z0 -z460
cell cOut    0 outside       sRPVo
cell cOutB   0 outside      -z0
cell cOutT   0 outside       z460

% ===================== RUN SETTINGS =====================
set pop 20000 250 50      % neutrons/cycle, active, inactive
set bc 1                  % vacuum (black) outer boundary
% set acelib "/path/to/jeff311.xsdir"   % <- set your library (600 K suffix)
set ures 1

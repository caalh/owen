% ===================== BAFFLE / FORMER + NEUTRON SHIELD =====================
% SS304 baffle plates in the peripheral reflector lattice cells (ported from the
% verified SCONE core): plate bands at local |x|,|y| in [8.36662, 10.58912] cm
% follow the stepped 193-assembly outline; water fills the rest of each cell.
surf bxp  px  8.36662
surf bxm  px -8.36662
surf bxP  px  10.58912
surf bxM  px -10.58912
surf byp  py  8.36662
surf bym  py -8.36662
surf byP  py  10.58912
surf byM  py -10.58912
% side baffles
cell bafl_w1 bafl water -bxp
cell bafl_p  bafl ss304 bxp -bxP
cell bafl_w2 bafl water bxP
cell bafr_w1 bafr water bxm
cell bafr_p  bafr ss304 bxM -bxm
cell bafr_w2 bafr water -bxM
cell baft_w1 baft water bym
cell baft_p  baft ss304 byM -bym
cell baft_w2 baft water -byM
cell bafb_w1 bafb water -byp
cell bafb_p  bafb ss304 byp -byP
cell bafb_w2 bafb water byP
% L-shaped corner baffles (SS = two plate bands; water = complement)
cell baftl_p1 baftl ss304 bxM -bxm -byP
cell baftl_p2 baftl ss304 byp -byP bxm
cell baftl_w  baftl water (-bxM:bxm:byP) (-bxm:-byp:byP)
cell baftr_p1 baftr ss304 bxp -bxP -byP
cell baftr_p2 baftr ss304 byp -byP -bxp
cell baftr_w  baftr water (-bxp:bxP:byP) (bxp:-byp:byP)
cell bafbl_p1 bafbl ss304 bxM -bxm byM
cell bafbl_p2 bafbl ss304 byM -bym bxm
cell bafbl_w  bafbl water (-bxM:bxm:-byM) (-byM:bym:-bxm)
cell bafbr_p1 bafbr ss304 bxp -bxP byM
cell bafbr_p2 bafbr ss304 byM -bym -bxp
cell bafbr_w  bafbr water (-bxp:bxP:-byM) (-byM:bym:bxp)
% square outer corners (single SS quadrant)
cell sqtl_p sqtl ss304 -bxm byp
cell sqtl_w sqtl water (bxm:-byp)
cell sqtr_p sqtr ss304 bxp byp
cell sqtr_w sqtr water (-bxp:-byp)
cell sqbl_p sqbl ss304 -bxm -bym
cell sqbl_w sqbl water (bxm:bym)
cell sqbr_p sqbr ss304 bxp -bym
cell sqbr_w sqbr water (-bxp:bym)


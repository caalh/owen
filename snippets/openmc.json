{
  "OpenMC Material": {
    "prefix": "omc-material",
    "body": [
      "${1:mat} = openmc.Material(name=\"${2:Material}\")",
      "${1:mat}.add_element(\"${3:U}\", ${4:1.0}, enrichment=${5:4.5})",
      "${1:mat}.set_density(\"g/cm3\", ${6:10.5})"
    ],
    "description": "OpenMC material definition"
  },
  "OpenMC Pin Universe": {
    "prefix": "omc-pin",
    "body": [
      "# --- ${1:Fuel Pin} Universe ---",
      "${2:fuel_cyl} = openmc.ZCylinder(r=${3:0.41})",
      "${4:clad_cyl} = openmc.ZCylinder(r=${5:0.47})",
      "",
      "fuel_cell = openmc.Cell(fill=${6:fuel}, region=-${2:fuel_cyl})",
      "clad_cell = openmc.Cell(fill=${7:clad}, region=+${2:fuel_cyl} & -${4:clad_cyl})",
      "mod_cell  = openmc.Cell(fill=${8:water}, region=+${4:clad_cyl})",
      "",
      "${9:pin} = openmc.Universe(cells=[fuel_cell, clad_cell, mod_cell])"
    ],
    "description": "OpenMC pin cell universe"
  },
  "OpenMC Rectangular Lattice": {
    "prefix": "omc-lattice",
    "body": [
      "lattice = openmc.RectLattice(name=\"${1:assembly}\")",
      "lattice.pitch = (${2:1.26}, ${2:1.26})",
      "lattice.lower_left = (${3:-10.71}, ${3:-10.71})",
      "lattice.universes = ${4:universes}"
    ],
    "description": "OpenMC rectangular lattice"
  },
  "OpenMC Settings": {
    "prefix": "omc-settings",
    "body": [
      "settings = openmc.Settings()",
      "settings.batches = ${1:200}",
      "settings.inactive = ${2:50}",
      "settings.particles = ${3:10000}",
      "settings.source = openmc.IndependentSource(",
      "    space=openmc.stats.Box(${4:lower}, ${5:upper}),",
      "    constraints={\"fissionable\": True},",
      ")"
    ],
    "description": "OpenMC eigenvalue settings"
  },
  "OpenMC Model": {
    "prefix": "omc-model",
    "body": [
      "model = openmc.model.Model(geometry, materials, settings, tallies)",
      "# model.export_to_model_xml()"
    ],
    "description": "OpenMC model export"
  },

  "OpenMC Full Pin Cell Script": {
    "prefix": "omc-pin-script",
    "scope": "python",
    "body": [
      "import openmc",
      "",
      "# --- Materials ---",
      "uo2 = openmc.Material(name='UO2')",
      "uo2.set_density('g/cm3', 10.97)",
      "uo2.add_nuclide('U235', 0.040, percent_type='ao')",
      "uo2.add_nuclide('U238', 0.960, percent_type='ao')",
      "uo2.add_nuclide('O16', 2.000, percent_type='ao')",
      "",
      "helium = openmc.Material(name='Helium')",
      "helium.set_density('g/cm3', 0.0001785)",
      "helium.add_element('He', 1.0)",
      "",
      "zircaloy = openmc.Material(name='Zircaloy-4')",
      "zircaloy.set_density('g/cm3', 6.56)",
      "zircaloy.add_element('Zr', 0.9824)",
      "zircaloy.add_element('Sn', 0.0145)",
      "zircaloy.add_element('Fe', 0.0021)",
      "zircaloy.add_element('Cr', 0.0010)",
      "",
      "water = openmc.Material(name='Water')",
      "water.set_density('g/cm3', 0.998)",
      "water.add_nuclide('H1', 2.0)",
      "water.add_nuclide('O16', 1.0)",
      "water.add_s_alpha_beta('c_H_in_H2O')",
      "",
      "materials = openmc.Materials([uo2, helium, zircaloy, water])",
      "",
      "# --- Geometry ---",
      "fuel_or = openmc.ZCylinder(r=0.4095)",
      "gap_or  = openmc.ZCylinder(r=0.4178)",
      "clad_or = openmc.ZCylinder(r=0.4750)",
      "box = openmc.model.RectangularPrism(width=1.26, height=1.26, boundary_type='reflective')",
      "",
      "fuel_cell = openmc.Cell(fill=uo2,      region=-fuel_or, name='fuel')",
      "gap_cell  = openmc.Cell(fill=helium,   region=+fuel_or & -gap_or, name='gap')",
      "clad_cell = openmc.Cell(fill=zircaloy, region=+gap_or  & -clad_or, name='clad')",
      "mod_cell  = openmc.Cell(fill=water,    region=+clad_or & -box, name='mod')",
      "fuel_cell.temperature = 900",
      "mod_cell.temperature  = 600",
      "",
      "geometry = openmc.Geometry([fuel_cell, gap_cell, clad_cell, mod_cell])",
      "",
      "# --- Settings ---",
      "settings = openmc.Settings()",
      "settings.run_mode = 'eigenvalue'",
      "settings.batches = ${1:100}",
      "settings.inactive = ${2:20}",
      "settings.particles = ${3:5000}",
      "settings.source = openmc.IndependentSource(",
      "    space=openmc.stats.Box((-0.63, -0.63, -1.0), (0.63, 0.63, 1.0)),",
      "    constraints={'fissionable': True},",
      ")",
      "",
      "model = openmc.model.Model(geometry, materials, settings)",
      "sp_path = model.run(threads=${4:4})",
      "with openmc.StatePoint(sp_path) as sp:",
      "    print('k-eff =', sp.keff)"
    ],
    "description": "Complete OpenMC pin-cell eigenvalue script"
  },

  "OpenMC Full Assembly Script": {
    "prefix": "omc-assembly-script",
    "scope": "python",
    "body": [
      "import openmc",
      "import numpy as np",
      "",
      "# --- Materials (shared) ---",
      "uo2 = openmc.Material(name='UO2')",
      "uo2.set_density('g/cm3', 10.97)",
      "uo2.add_nuclide('U235', 0.040)",
      "uo2.add_nuclide('U238', 0.960)",
      "uo2.add_nuclide('O16', 2.000)",
      "",
      "water = openmc.Material(name='Water')",
      "water.set_density('g/cm3', 0.998)",
      "water.add_nuclide('H1', 2.0)",
      "water.add_nuclide('O16', 1.0)",
      "water.add_s_alpha_beta('c_H_in_H2O')",
      "",
      "zr = openmc.Material(name='Zircaloy')",
      "zr.set_density('g/cm3', 6.56)",
      "zr.add_element('Zr', 1.0)",
      "",
      "materials = openmc.Materials([uo2, water, zr])",
      "",
      "# --- Pin universes ---",
      "def fuel_pin():",
      "    fuel = openmc.ZCylinder(r=0.4095)",
      "    clad = openmc.ZCylinder(r=0.4750)",
      "    c1 = openmc.Cell(fill=uo2,   region=-fuel)",
      "    c2 = openmc.Cell(fill=zr,    region=+fuel & -clad)",
      "    c3 = openmc.Cell(fill=water, region=+clad)",
      "    return openmc.Universe(cells=[c1, c2, c3])",
      "",
      "def guide_tube():",
      "    g = openmc.ZCylinder(r=0.6020)",
      "    c1 = openmc.Cell(fill=water, region=-g)",
      "    c2 = openmc.Cell(fill=water, region=+g)",
      "    return openmc.Universe(cells=[c1, c2])",
      "",
      "F = fuel_pin()",
      "G = guide_tube()",
      "",
      "# --- 17x17 lattice ---",
      "lat = openmc.RectLattice(name='PWR-17x17')",
      "lat.pitch = (1.26, 1.26)",
      "lat.lower_left = (-10.71, -10.71)",
      "univ_map = np.full((17, 17), F, dtype=object)",
      "for (i, j) in [(2,5),(2,8),(2,11), (5,2),(5,5),(5,8),(5,11),(5,14),",
      "               (8,2),(8,5),(8,8),(8,11),(8,14),",
      "               (11,2),(11,5),(11,8),(11,11),(11,14),",
      "               (14,5),(14,8),(14,11)]:",
      "    univ_map[i, j] = G",
      "lat.universes = univ_map.tolist()",
      "",
      "box = openmc.model.RectangularPrism(width=17*1.26, height=17*1.26,",
      "                                    boundary_type='reflective')",
      "root = openmc.Cell(fill=lat, region=-box)",
      "geometry = openmc.Geometry([root])",
      "",
      "settings = openmc.Settings()",
      "settings.batches = ${1:150}",
      "settings.inactive = ${2:50}",
      "settings.particles = ${3:10000}",
      "settings.source = openmc.IndependentSource(",
      "    space=openmc.stats.Box((-10.0, -10.0, -1.0), (10.0, 10.0, 1.0)),",
      "    constraints={'fissionable': True},",
      ")",
      "",
      "model = openmc.model.Model(geometry, materials, settings)",
      "sp_path = model.run(threads=${4:4})",
      "with openmc.StatePoint(sp_path) as sp:",
      "    print('k-eff =', sp.keff)"
    ],
    "description": "Complete OpenMC 17x17 fuel assembly eigenvalue script"
  }
}

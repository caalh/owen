{
  "SCONE Pin Universe": {
    "prefix": "scpin",
    "body": [
      "${1:fuelPin} { id ${2:100}; type pinUniverse;",
      "              radii (${3:0.392 0.400 0.457} 0.0);",
      "              fills (${4:UO2 Helium Zircaloy Water}); }"
    ],
    "description": "SCONE pin universe"
  },
  "SCONE Material": {
    "prefix": "scmat",
    "body": [
      "${1:UO2} {",
      "  temp ${2:600};",
      "  composition {",
      "    ${3:92235.06}  ${4:7.2175E-04};",
      "    ${5:92238.06}  ${6:2.2253E-02};",
      "     ${7:8016.06}  ${8:4.5853E-02}; }",
      "}"
    ],
    "description": "SCONE material definition"
  },
  "SCONE Geometry": {
    "prefix": "scgeo",
    "body": [
      "geometry {",
      "  type geometryStd;",
      "  boundary (${1:0 0 0 0 0 0});",
      "  graph {type shrunk;}",
      "",
      "  surfaces {",
      "    ${2:boundary} { id ${3:1}; type ${4:zSquareCylinder};",
      "                   origin (0.0 0.0 0.0); halfwidth (${5:0.63 0.63} 0.0); }",
      "  }",
      "",
      "  cells {",
      "    inner { id 1; surfaces (-${3:1}); filltype uni; universe ${6:100}; }",
      "    outer { id 2; surfaces (${3:1}); filltype outside; }",
      "  }",
      "",
      "  universes {",
      "    root { id 1; type rootUniverse; border ${3:1}; fill u<${6:100}>; }",
      "    $0",
      "  }",
      "}"
    ],
    "description": "SCONE geometry block"
  },

  "SCONE Tutorial - Fuel Pin (test lib)": {
    "prefix": "scone-tutorial-fuel-pin",
    "scope": "scone",
    "body": [
      "type eigenPhysicsPackage;",
      "",
      "pop      ${1:20000};",
      "active   ${2:100};",
      "inactive ${3:50};",
      "XSdata   ce;",
      "dataType ce;",
      "",
      "collisionOperator { neutronCE { type neutronCEstd; } }",
      "",
      "transportOperator { type transportOperatorST; }",
      "",
      "inactiveTally {}",
      "activeTally {",
      "  flux { type collisionClerk;",
      "         response (flux);",
      "         flux { type fluxResponse; } }",
      "}",
      "",
      "geometry {",
      "  type geometryStd;",
      "  boundary (1 1 1 1 1 1);",
      "  graph {type shrunk;}",
      "",
      "  surfaces {",
      "    bound { id 1; type zSquareCylinder;",
      "            origin (0.0 0.0 0.0); halfwidth (0.63 0.63 0.0); }",
      "  }",
      "  cells {",
      "    inner { id 1; surfaces (-1); filltype uni; universe 100; }",
      "    outer { id 2; surfaces ( 1); filltype outside; }",
      "  }",
      "  universes {",
      "    root { id 1; type rootUniverse; border 1; fill u<100>; }",
      "    pin  { id 100; type pinUniverse;",
      "           radii (0.392 0.400 0.457 0.0);",
      "           fills (UO2 Helium Zircaloy Water); }",
      "  }",
      "}",
      "",
      "nuclearData {",
      "  handles { ce { type aceNeutronDatabase; ures 0; aceLibrary testLib; } }",
      "  materials {",
      "    UO2 { temp 600; composition {",
      "      92235.06  7.2175E-04;",
      "      92238.06  2.2253E-02;",
      "       8016.06  4.5853E-02; } }",
      "    Helium { temp 600; composition { 2004.06 2.6E-04; } }",
      "    Zircaloy { temp 600; composition {",
      "      40090.06  2.18E-02;",
      "      40091.06  4.76E-03;",
      "      40092.06  7.28E-03;",
      "      40094.06  7.38E-03;",
      "      40096.06  1.19E-03; } }",
      "    Water { temp 600; moder { 1001.06 h-h2o.42t; }",
      "             composition {",
      "               1001.06 6.7E-02;",
      "               8016.06 3.35E-02; } }",
      "  }",
      "}"
    ],
    "description": "SCONE fuel-pin eigenvalue deck (testLib ACE)"
  },

  "SCONE Tutorial - 5x5 Assembly (test lib)": {
    "prefix": "scone-tutorial-5x5-assembly",
    "scope": "scone",
    "body": [
      "type eigenPhysicsPackage;",
      "",
      "pop      ${1:30000};",
      "active   ${2:150};",
      "inactive ${3:60};",
      "XSdata   ce;",
      "dataType ce;",
      "",
      "collisionOperator { neutronCE { type neutronCEstd; } }",
      "transportOperator { type transportOperatorST; }",
      "",
      "geometry {",
      "  type geometryStd;",
      "  boundary (1 1 1 1 1 1);",
      "  graph {type shrunk;}",
      "",
      "  surfaces {",
      "    bound { id 1; type box; origin (0.0 0.0 0.0); halfwidth (3.15 3.15 0.0); }",
      "  }",
      "  cells {",
      "    inner { id 1; surfaces (-1); filltype uni; universe 200; }",
      "    outer { id 2; surfaces ( 1); filltype outside; }",
      "  }",
      "  universes {",
      "    root { id 1; type rootUniverse; border 1; fill u<200>; }",
      "    pin  { id 100; type pinUniverse;",
      "           radii (0.392 0.400 0.457 0.0);",
      "           fills (UO2 Helium Zircaloy Water); }",
      "    lat  { id 200; type latUniverse;",
      "           shape (5 5 1); pitch (1.26 1.26 1.26); origin (0.0 0.0 0.0);",
      "           padMat Water;",
      "           map (",
      "             100 100 100 100 100",
      "             100 100 100 100 100",
      "             100 100 100 100 100",
      "             100 100 100 100 100",
      "             100 100 100 100 100); }",
      "  }",
      "}"
    ],
    "description": "SCONE 5x5 assembly lattice universe (geometry block only)"
  },

  "SCONE Tutorial - Shielding Slab": {
    "prefix": "scone-tutorial-shielding-slab",
    "scope": "scone",
    "body": [
      "type fixedSourcePhysicsPackage;",
      "",
      "pop      ${1:20000};",
      "active   ${2:1};",
      "inactive ${3:0};",
      "XSdata   ce;",
      "dataType ce;",
      "",
      "collisionOperator { neutronCE { type neutronCEstd; } }",
      "transportOperator { type transportOperatorST; }",
      "",
      "source {",
      "  type pointSource;",
      "  r (-5.0 0.0 0.0);",
      "  particle neutron;",
      "  E ${4:1.0};",
      "}",
      "",
      "geometry {",
      "  type geometryStd;",
      "  boundary (0 0 0 0 0 0);",
      "  graph {type shrunk;}",
      "  surfaces {",
      "    left  { id 1; type xPlane; x0 -10.0; }",
      "    right { id 2; type xPlane; x0  30.0; }",
      "    front { id 3; type xPlane; x0   0.0; }",
      "  }",
      "  cells {",
      "    air  { id 1; surfaces ( 1 -3); filltype mat; material Air; }",
      "    slab { id 2; surfaces ( 3 -2); filltype mat; material Steel; }",
      "  }",
      "  universes { root { id 1; type rootUniverse; border 2; fill outside; } }",
      "}"
    ],
    "description": "SCONE point-source shielding slab (fixed-source)"
  }
}

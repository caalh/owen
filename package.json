{
  "name": "owen-neutronics",
  "displayName": "OWEN — Open Workspace for Engineered Neutronics",
  "description": "Nuclear reactor modeling toolkit: syntax highlighting, lattice builder, geometry preview, validation, and workflow automation for MCNP, OpenMC, Serpent, and SCONE.",
  "version": "0.4.2",
  "publisher": "belvoirdynamics",
  "author": "Aaron W. Calhoun",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "assets/owen-icon.png",
  "homepage": "https://reactormc.net",
  "bugs": {
    "url": "https://github.com/caalh/owen/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/caalh/owen.git"
  },
  "qna": "marketplace",
  "galleryBanner": {
    "color": "#0b1020",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Other"
  ],
  "keywords": [
    "mcnp",
    "openmc",
    "serpent",
    "scone",
    "nuclear",
    "monte-carlo",
    "reactor",
    "neutronics",
    "lattice"
  ],
  "activationEvents": [
    "onLanguage:mcnp",
    "onLanguage:serpent",
    "onLanguage:scone",
    "onLanguage:python",
    "onCommand:owen.openLatticeBuilder",
    "onCommand:owen.openInputBuilder",
    "onCommand:owen.openAllen",
    "onCommand:owen.validateInput",
    "onCommand:owen.runSimulation",
    "onCommand:owen.openGeometryPreview",
    "onCommand:owen.searchReactorLibrary",
    "onCommand:owen.openPrebuiltModel",
    "onCommand:owen.insertMaterial",
    "onCommand:owen.openTutorial",
    "onCommand:owen.runSweep",
    "onCommand:owen.chooseHighlightPalette",
    "onCommand:owen.toggleInvisibleCharacters",
    "onCommand:owen.showMcnpReferences",
    "onView:owenMcnpReferences",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configurationDefaults": {
      "[mcnp]": {
        "editor.occurrencesHighlight": "singleFile",
        "editor.selectionHighlight": false
      }
    },
    "languages": [
      {
        "id": "mcnp",
        "aliases": [
          "MCNP",
          "mcnp"
        ],
        "extensions": [
          ".i",
          ".mcnp",
          ".inp"
        ],
        "configuration": "./language-configuration/mcnp.language-configuration.json"
      },
      {
        "id": "serpent",
        "aliases": [
          "Serpent",
          "serpent"
        ],
        "extensions": [
          ".serp"
        ],
        "configuration": "./language-configuration/serpent.language-configuration.json"
      },
      {
        "id": "scone",
        "aliases": [
          "SCONE",
          "scone"
        ],
        "extensions": [
          ".scone"
        ],
        "configuration": "./language-configuration/scone.language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mcnp",
        "scopeName": "source.mcnp",
        "path": "./syntaxes/mcnp.tmLanguage.json"
      },
      {
        "language": "serpent",
        "scopeName": "source.serpent",
        "path": "./syntaxes/serpent.tmLanguage.json"
      },
      {
        "language": "scone",
        "scopeName": "source.scone",
        "path": "./syntaxes/scone.tmLanguage.json"
      },
      {
        "scopeName": "openmc.injection",
        "path": "./syntaxes/openmc.injection.tmLanguage.json",
        "injectTo": [
          "source.python"
        ]
      }
    ],
    "commands": [
      {
        "command": "owen.openAllen",
        "title": "OWEN: Open ALLEN Cross-Sections",
        "category": "OWEN",
        "icon": "$(graph-line)"
      },
      {
        "command": "owen.openLatticeBuilder",
        "title": "OWEN: Open Lattice Builder",
        "category": "OWEN"
      },
      {
        "command": "owen.openInputBuilder",
        "title": "OWEN: Open Input Builder",
        "category": "OWEN"
      },
      {
        "command": "owen.validateInput",
        "title": "OWEN: Validate Input File",
        "category": "OWEN"
      },
      {
        "command": "owen.runSimulation",
        "title": "OWEN: Run Simulation",
        "category": "OWEN"
      },
      {
        "command": "owen.openGeometryPreview",
        "title": "OWEN: Open 3D Geometry Preview",
        "category": "OWEN"
      },
      {
        "command": "owen.searchReactorLibrary",
        "title": "OWEN: Search Reactor Library",
        "category": "OWEN"
      },
      {
        "command": "owen.openPrebuiltModel",
        "title": "OWEN: Open Prebuilt Model…",
        "category": "OWEN"
      },
      {
        "command": "owen.insertMaterial",
        "title": "OWEN: Insert Material from Database",
        "category": "OWEN"
      },
      {
        "command": "owen.openTutorial",
        "title": "OWEN: Open Tutorial",
        "category": "OWEN"
      },
      {
        "command": "owen.runSweep",
        "title": "OWEN: Run Parameter Sweep",
        "category": "OWEN"
      },
      {
        "command": "owen.chooseHighlightPalette",
        "title": "OWEN: Choose Highlight Palette",
        "category": "OWEN"
      },
      {
        "command": "owen.toggleInvisibleCharacters",
        "title": "OWEN: Toggle Invisible Characters",
        "category": "OWEN"
      },
      {
        "command": "owen.showMcnpReferences",
        "title": "OWEN: Show MCNP References (Cross-Reference Tracker)",
        "category": "OWEN",
        "icon": "$(references)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "owen",
          "title": "OWEN",
          "icon": "assets/owen-icon.png"
        }
      ]
    },
    "views": {
      "owen": [
        {
          "id": "owenMcnpReferences",
          "name": "MCNP References",
          "icon": "$(references)",
          "contextualTitle": "OWEN MCNP References"
        }
      ]
    },
    "submenus": [
      {
        "id": "owen.contextMenu",
        "label": "OWEN"
      },
      {
        "id": "owen.editorTitleMenu",
        "label": "OWEN",
        "icon": "$(beaker)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "submenu": "owen.editorTitleMenu",
          "group": "navigation@100",
          "when": "editorLangId =~ /^(mcnp|serpent|scone|python)$/"
        }
      ],
      "owen.editorTitleMenu": [
        {
          "command": "owen.openAllen",
          "group": "1_analyze@0"
        },
        {
          "command": "owen.validateInput",
          "group": "1_analyze@1"
        },
        {
          "command": "owen.insertMaterial",
          "group": "1_analyze@2"
        },
        {
          "command": "owen.openPrebuiltModel",
          "group": "1_analyze@3"
        },
        {
          "command": "owen.showMcnpReferences",
          "group": "1_analyze@4",
          "when": "editorLangId == mcnp"
        },
        {
          "command": "owen.openInputBuilder",
          "group": "2_build@0"
        },
        {
          "command": "owen.openLatticeBuilder",
          "group": "2_build@1"
        },
        {
          "command": "owen.openGeometryPreview",
          "group": "2_build@2"
        },
        {
          "command": "owen.runSimulation",
          "group": "3_run@1"
        },
        {
          "command": "owen.runSweep",
          "group": "3_run@2"
        },
        {
          "command": "owen.toggleInvisibleCharacters",
          "group": "4_view@1"
        },
        {
          "command": "owen.chooseHighlightPalette",
          "group": "4_view@2"
        },
        {
          "command": "owen.openTutorial",
          "group": "5_help@1"
        },
        {
          "command": "owen.searchReactorLibrary",
          "group": "5_help@2"
        }
      ],
      "editor/context": [
        {
          "submenu": "owen.contextMenu",
          "group": "owen@1",
          "when": "editorTextFocus && editorLangId =~ /^(mcnp|serpent|scone|python)$/"
        }
      ],
      "owen.contextMenu": [
        {
          "command": "owen.openAllen",
          "group": "1_analyze@0"
        },
        {
          "command": "owen.validateInput",
          "group": "1_analyze@1"
        },
        {
          "command": "owen.insertMaterial",
          "group": "1_analyze@2"
        },
        {
          "command": "owen.openPrebuiltModel",
          "group": "1_analyze@3"
        },
        {
          "command": "owen.showMcnpReferences",
          "group": "1_analyze@4",
          "when": "editorLangId == mcnp"
        },
        {
          "command": "owen.openInputBuilder",
          "group": "2_build@0"
        },
        {
          "command": "owen.openLatticeBuilder",
          "group": "2_build@1"
        },
        {
          "command": "owen.openGeometryPreview",
          "group": "2_build@2"
        },
        {
          "command": "owen.runSimulation",
          "group": "3_run@1"
        },
        {
          "command": "owen.runSweep",
          "group": "3_run@2"
        },
        {
          "command": "owen.openTutorial",
          "group": "4_help@1"
        },
        {
          "command": "owen.searchReactorLibrary",
          "group": "4_help@2"
        },
        {
          "command": "owen.chooseHighlightPalette",
          "group": "5_appearance@1"
        },
        {
          "command": "owen.toggleInvisibleCharacters",
          "group": "5_appearance@2"
        }
      ],
      "commandPalette": [
        {
          "command": "owen.showMcnpReferences",
          "when": "editorLangId == mcnp"
        }
      ],
      "view/title": [
        {
          "command": "owen.showMcnpReferences",
          "when": "view == owenMcnpReferences",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "OWEN",
      "properties": {
        "owen.openmc.executable": {
          "type": "string",
          "default": "openmc",
          "description": "Path to the OpenMC executable. Used only for non-Python OpenMC entry points; Python model scripts run via 'owen.openmc.pythonExecutable'."
        },
        "owen.openmc.pythonExecutable": {
          "type": "string",
          "default": "python",
          "description": "Python interpreter used to run OpenMC model scripts (e.g. build_model.py)."
        },
        "owen.mcnp.executable": {
          "type": "string",
          "default": "mcnp6",
          "description": "Path to the MCNP executable."
        },
        "owen.mcnp.lineLengthLimit": {
          "type": "integer",
          "default": 80,
          "minimum": 1,
          "description": "MCNP card-image column limit. Lines longer than this are flagged (Problems + an in-editor decoration) because characters past the limit are silently ignored by MCNP. The classic limit is 80 columns (MCNP5 / MCNP6.1 and earlier); set to 128 for MCNP6.2+. Also drives the language-scoped ruler shown in MCNP files."
        },
        "owen.serpent.executable": {
          "type": "string",
          "default": "sss2",
          "description": "Path to the Serpent executable."
        },
        "owen.scone.executable": {
          "type": "string",
          "default": "scone",
          "description": "Path to the SCONE executable. On Windows, SCONE typically requires WSL."
        },
        "owen.simulation.workingDirectory": {
          "type": "string",
          "default": "",
          "description": "Working directory for simulation runs. Defaults to file's directory."
        },
        "owen.community.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the Community Library browser. Requires owen.supabase.url and owen.supabase.anonKey."
        },
        "owen.supabase.url": {
          "type": "string",
          "default": "",
          "description": "Supabase project URL backing the Community Library (e.g. https://xxxx.supabase.co)."
        },
        "owen.supabase.anonKey": {
          "type": "string",
          "default": "",
          "description": "Supabase anon (public) API key for the Community Library."
        },
        "owen.nrdp.live": {
          "type": "boolean",
          "default": true,
          "description": "Fetch NRDP data live from reactormc.net when online; falls back to bundled snapshot."
        },
        "owen.nrdp.endpoint": {
          "type": "string",
          "default": "https://reactormc.net/data",
          "description": "Base URL for live NRDP material/element snapshots (expects nrdp-materials.json and nrdp-elements.json)."
        },
        "owen.allen.dataBaseUrl": {
          "type": "string",
          "default": "https://reactormc.net/data/allen",
          "description": "Base URL for ALLEN cross-section JSON (index.json and endfb80/ curves). Override for offline or local NRDP dev servers."
        },
        "owen.preview.maxInstances": {
          "type": "integer",
          "default": 1500000,
          "minimum": 50000,
          "description": "Maximum number of cylinder instances the 3D Geometry Preview will render. The webview batches geometry into instanced meshes, so draw calls stay low regardless; this caps total instances to bound memory/CPU. When a deck's requested fidelity would exceed this, OWEN auto-simplifies detail (concentric layers → single discs, then collapses axial segments) instead of hiding pins. Raise it (e.g. 4000000) to view a full BEAVRS core at concentric-shell + axial detail on a powerful machine; lower it on constrained hardware."
        },
        "owen.highlight.mcnp.palette": {
          "type": "string",
          "enum": [
            "Classic",
            "Solarized",
            "High Contrast",
            "Pastel"
          ],
          "enumDescriptions": [
            "VS Code dark default-style colors",
            "Muted Solarized-inspired accents",
            "Bright, vivid, maximum legibility",
            "Soft low-saturation tones"
          ],
          "default": "Classic",
          "description": "Color palette applied to MCNP syntax tokens (comments, keywords, surfaces, materials, tallies, numbers, ZAIDs). Applied live via editor.tokenColorCustomizations."
        },
        "owen.highlight.openmc.palette": {
          "type": "string",
          "enum": [
            "Classic",
            "Solarized",
            "High Contrast",
            "Pastel"
          ],
          "enumDescriptions": [
            "VS Code dark default-style colors",
            "Muted Solarized-inspired accents",
            "Bright, vivid, maximum legibility",
            "Soft low-saturation tones"
          ],
          "default": "Classic",
          "description": "Color palette applied to OpenMC API tokens inside Python files (openmc module, classes, functions, submodules) via an injection grammar. Applied live via editor.tokenColorCustomizations."
        },
        "owen.highlight.serpent.palette": {
          "type": "string",
          "enum": [
            "Classic",
            "Solarized",
            "High Contrast",
            "Pastel"
          ],
          "enumDescriptions": [
            "VS Code dark default-style colors",
            "Muted Solarized-inspired accents",
            "Bright, vivid, maximum legibility",
            "Soft low-saturation tones"
          ],
          "default": "Classic",
          "description": "Color palette applied to Serpent syntax tokens (comments, keywords, materials, cells/pins/surfaces, numbers, strings, ZAIDs). Applied live via editor.tokenColorCustomizations."
        },
        "owen.highlight.scone.palette": {
          "type": "string",
          "enum": [
            "Classic",
            "Solarized",
            "High Contrast",
            "Pastel"
          ],
          "enumDescriptions": [
            "VS Code dark default-style colors",
            "Muted Solarized-inspired accents",
            "Bright, vivid, maximum legibility",
            "Soft low-saturation tones"
          ],
          "default": "Classic",
          "description": "Color palette applied to SCONE syntax tokens (comments, keywords, block/section names, numbers, strings). Applied live via editor.tokenColorCustomizations."
        }
      }
    },
    "snippets": [
      {
        "language": "mcnp",
        "path": "./snippets/mcnp.json"
      },
      {
        "language": "python",
        "path": "./snippets/openmc.json"
      },
      {
        "language": "serpent",
        "path": "./snippets/serpent.json"
      },
      {
        "language": "scone",
        "path": "./snippets/scone.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run typecheck && node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package",
    "publish": "vsce publish",
    "export-nrdp": "node ./scripts/export-nrdp-snapshot.mjs",
    "export-tutorials": "node ./scripts/export-tutorial-links.mjs"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.3.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0"
  }
}
